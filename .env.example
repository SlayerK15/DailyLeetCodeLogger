# PostgreSQL — use Neon (neon.tech) for a free Vercel-compatible DB
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# In production, set this to your Vercel URL
NEXTAUTH_URL="http://localhost:3000"

# Claude API — primary (get from console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-..."

# OpenRouter API — fallback (get from openrouter.ai/keys)
OPENROUTER_API_KEY="sk-or-..."

# Gmail account to send reminder emails from
EMAIL_USER="yourapp@gmail.com"
EMAIL_PASS="xxxx xxxx xxxx xxxx"   # Gmail App Password (not your account password)

# Generate with: openssl rand -hex 32
# Vercel automatically sends this as the Authorization header to cron routes
CRON_SECRET="your-cron-secret-here"
